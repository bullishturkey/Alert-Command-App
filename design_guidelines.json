  "instructions_to_main_agent": [
    "Use React Native StyleSheet.create() for all styles. Do not use CSS files.",
    "Use 'expo-router' for navigation. Create screens in the 'app/' directory.",
    "Use '@expo/vector-icons' (Ionicons or Feather) for icons.",
    "For charts, use 'react-native-webview' to render a lightweight HTML/JS chart (e.g., TradingView Lightweight Charts) or a native library if simpler.",
    "Ensure all touch targets are at least 44x44 points.",
    "Dark mode is default. Hardcode dark colors or use a custom theme provider if dynamic switching is needed (but user preferred dark default).",
    "Use the 'primary_color' (#00C805) for positive price changes and 'secondary_color' (#FF5000) for negative price changes.",
    "For the 'NDX Command' feel, keep the UI minimal. Avoid gradients unless subtle.",
    "For Authentication, use JWT stored in SecureStore.",
    "For Backend, ensure FastAPI endpoints return JSON that matches the frontend data structures.",
    "Use 'FlatList' for lists (Alerts, News, Stocks) for performance.",
    "Add 'data-testid' to all interactive elements for testing.",
    "Stock Cards should show: Ticker, Price (Large), % Change (Color coded), and a mini sparkline if possible (or just the numbers).",
    "News Feed should use the 'news_header' image as a parallax header if possible, or just a clean list."
  ],
  "universal_guidelines": [
    "Mobile-first design principles apply strictly.",
    "Avoid clutter. Show only essential data on the main dashboard.",
    "Use skeleton loaders for data fetching states.",
    "Error handling must be graceful (toast notifications or inline errors).",
    "All text must be readable against the dark background (ensure contrast > 4.5:1).",
    "Use 'SafeAreaView' to handle notches and home indicators."
  ]
}